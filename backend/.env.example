MONGODB_URL=mongodb+srv://<username>:<password>@<cluster-name>.mongodb.net/?appName=<app-name>
DB_NAME=ethara_db
JWT_SECRET_KEY=replace-with-a-secure-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
APP_TITLE=Team Task Manager API
# Comma-separated frontend origins (no trailing slash), or "*" for any origin (dev only)
CORS_ORIGINS=*
# Keep false unless you use cookie-based auth
CORS_ALLOW_CREDENTIALS=false
# Optional: allow preview URLs, example: https://.*\.vercel\.app
CORS_ALLOW_ORIGIN_REGEX=
ADMIN_SIGNUP_CODE=replace-with-strong-admin-invite-code
